msgstr "Kupac obavešten · stiže do %(time)s"

#: deliveries/views.py:224
msgid "Message not sent — try again later."
msgstr "Poruka nije poslata — pokušajte kasnije."

#: deliveries/views.py:261
msgid "Unable to resend."
msgstr "Nije moguće ponovo poslati."

#: deliveries/views.py:263
msgid "Message resent."
msgstr "Poruka je ponovo poslata."

#: deliveries/views.py:265
msgid "Message not sent — check the number."
msgstr "Poruka nije poslata — proverite broj."

#: deliveries/views.py:277
msgid "Marked as delivered."
msgstr "Označeno kao isporučeno."

#: deliveries/views.py:312
msgid "Delivery deleted."
msgstr "Dostava je obrisana."

#: deliveries/views.py:338
msgid "Delivery restored."
msgstr "Dostava je vraćena."

