#: deliveries/views.py:116
msgid "Saved."
msgstr "Sačuvano."

#: deliveries/views.py:121
msgid ""
"Name saved, but we could not recognize the address. Please check and try "
"again."
msgstr ""
"Naziv je sačuvan, ali nismo prepoznali adresu. Proverite je i pokušajte "
"ponovo."

#: deliveries/views.py:154
msgid "Delivery added."
msgstr "Dostava je dodata."

#: deliveries/views.py:156
msgid "The number is not a Serbian mobile — please check."
msgstr "Broj nije srpski mobilni — proverite ga."

#: deliveries/views.py:160
msgid "We could not recognize the address — please check it later."
msgstr "Nismo prepoznali adresu — proverite je kasnije."

#: deliveries/views.py:169
msgid "First set your store address."
msgstr "Prvo podesite adresu prodavnice."

