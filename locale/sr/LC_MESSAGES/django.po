msgid "Create an order (customer address + phone)"
msgstr "Napravite porudžbinu (adresa kupca + telefon)"

#: deliveries/templates/deliveries/api_docs.html:19
msgid ""
"Mark “delivery started” → customer gets a notification and a tracking link"
msgstr ""
"Označite „dostava započeta“ → kupac dobija obaveštenje i link za praćenje"

#: deliveries/templates/deliveries/api_docs.html:20
msgid "Delivery status and rating"
msgstr "Status dostave i ocena"

