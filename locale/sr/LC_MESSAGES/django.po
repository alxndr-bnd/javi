#: deliveries/services.py:104
msgid "Store address is not geocoded — open “Store” and save the address."
msgstr "Adresa prodavnice nije geokodirana — otvorite „Prodavnica“ i sačuvajte adresu."

#: deliveries/services.py:106
msgid ""
"We could not recognize the delivery address — check the recipient address."
msgstr ""
"Nismo prepoznali adresu dostave — proverite adresu primaoca."

#: deliveries/services.py:107
msgid "The map can't compute a route right now — enter the time manually."
msgstr "Mapa trenutno ne može da izračuna rutu — unesite vreme ručno."

#: deliveries/services.py:127
#, python-format
msgid ""
"Your order from %(shop)s is on its way. Arriving approximately by %(time)s. "
"Track: %(link)s"
msgstr ""
"Vaša porudžbina iz %(shop)s je u dostavi. Stiže okvirno do %(time)s. "
"Pratite: %(link)s"

#: deliveries/services.py:236
#, python-format
msgid "How did the delivery from %(shop)s go? Rate it: %(link)s"
msgstr "Kako je prošla dostava iz %(shop)s? Ocenite: %(link)s"

