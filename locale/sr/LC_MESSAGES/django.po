#: deliveries/templates/deliveries/api_docs.html:14
msgid ""
"Create an API key and send orders directly from your system — Javi notifies "
"your customers about the delivery."
msgstr ""
"Napravite API ključ i šaljite porudžbine direktno iz svog sistema — Javi "
"obaveštava vaše kupce o dostavi."

#: deliveries/templates/deliveries/api_docs.html:17
msgid "Generate an API key in your profile"
msgstr "Generišite API ključ u svom profilu"

