msgid ""
"in development — bugs and outages are possible, do not rely on stability"
msgstr ""
"u razvoju — moguće su greške i prekidi, ne oslanjajte se na stabilnost"

#: tracking/templates/tracking/status.html:3
#: tracking/templates/tracking/status.html:24
msgid "Delivery status"
msgstr "Status dostave"

#: tracking/templates/tracking/status.html:8
msgid "Link has expired."
msgstr "Link je istekao."

#: tracking/templates/tracking/status.html:14
msgid "Your order has been delivered"
msgstr "Vaša porudžbina je isporučena"

#: tracking/templates/tracking/status.html:16
msgid "Your order is on its way"
msgstr "Vaša porudžbina je u dostavi"

#: tracking/templates/tracking/status.html:17
#, python-format
msgid "Arriving approximately by %(eta)s"
msgstr "Stiže okvirno do %(eta)s"

#: tracking/templates/tracking/status.html:19
msgid "Your order has been received"
msgstr "Vaša porudžbina je primljena"

#: tracking/templates/tracking/status.html:36
msgid "I received the order"
msgstr "Primio sam porudžbinu"

#: tracking/templates/tracking/status.html:41
#, python-format
msgid "Thank you for your rating! Your rating: %(rating)s★"
msgstr "Hvala na oceni! Vaša ocena: %(rating)s★"

#: tracking/templates/tracking/status.html:44
msgid "How did the delivery go?"
msgstr "Kako je prošla dostava?"

#: tracking/templates/tracking/status.html:45
msgid "Tap the stars to rate (1 = poor, 5 = excellent)."
msgstr "Dodirnite zvezdice da ocenite (1 = loše, 5 = odlično)."

#: tracking/templates/tracking/status.html:50
#, python-format
msgid "Rating %(n)s of 5"
msgstr "Ocena %(n)s od 5"

#: tracking/templates/tracking/status.html:57
msgid "Unsubscribe from notifications"
msgstr "Odjavi se sa obaveštenja"

#: tracking/templates/tracking/unsubscribed.html:3
msgid "Unsubscribe"
msgstr "Odjava"

#: tracking/templates/tracking/unsubscribed.html:7
msgid "You have been unsubscribed."
msgstr "Odjavljeni ste."

#: tracking/templates/tracking/unsubscribed.html:8
msgid "We will no longer send you rating messages."
msgstr "Više vam nećemo slati poruke o ocenjivanju."

#: tracking/views.py:64
msgid "Too many requests. Try again later."
msgstr "Previše zahteva. Pokušajte kasnije."
