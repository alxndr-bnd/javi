# Javi — пример переменных окружения (локально скопируй в .env)
SECRET_KEY=django-insecure-dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://javi.serbito.rs

# БД. Локально можно оставить пустым (sqlite). Прод — Cloud SQL serbitodb, база javi:
# DATABASE_URL=postgres://javi:PASSWORD@/javi?host=/cloudsql/serbito:europe-west1:serbitodb
# Локальный Postgres в Docker:
# DATABASE_URL=postgres://javi:javi@127.0.0.1:5432/javi

# Google Maps — ключ Geocoding API (прод: секрет javi-google-maps-key в Secret Manager).
# Пусто = геокодинг вернёт «не распознано» (для локалки без ключа используйте фейк-провайдер).
GOOGLE_MAPS_API_KEY=
# MAPS_PROVIDER=integrations.google_maps.GoogleMapsProvider
# ROUTES_PROVIDER=integrations.google_maps.GoogleRoutesProvider

# Infobip (мессенджинг, Epic 2). Ключ — прод: секрет javi-infobip-key.
INFOBIP_API_KEY=
# INFOBIP_BASE_URL=https://m9dw19.api.infobip.com
# INFOBIP_SENDER=IBSelfServe
# INFOBIP_CHANNEL=viber   # viber | sms
# PUBLIC_BASE_URL=https://javi.serbito.rs
